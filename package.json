{
  "name": "gth-pricing",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@supabase/supabase-js": "^2.99.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "start:test": "env-cmd -f .env.test react-scripts start",
    "start:prod": "env-cmd -f .env.production react-scripts start",
